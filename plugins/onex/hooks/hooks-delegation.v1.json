{
  "$schema": "https://claude.ai/schemas/hooks.json",
  "description": "OmniClaude Delegation Hooks - Minimal hook config for delegation interception, cost accounting, and prompt classification",
  "version": "1.0.0",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-end.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Agent|Task)$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre_tool_use_delegation.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Agent|Task)$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post_tool_use_cost_accounting.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/user_prompt_delegation_classifier.sh"
          }
        ]
      }
    ]
  }
}
