<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ai.omninode.cron-closeout.plist — launchd agent for periodic close-out + build loop [OMN-7842]

  Invokes cron-closeout.sh which runs the full headless close-out pipeline:
  phases A-E (merge-sweep, quality gates, release, verification) and phases
  F1-F3 (build loop: ticket fill, classify, dispatch).

  The script internally generates ONEX_RUN_ID for session correlation and
  sources ~/.omnibase/.env for credentials.

  Template: __OMNI_HOME__ and __HOME__ are expanded at install time by tick-bundle-install.sh.

  Install:
    bash omniclaude/scripts/tick-bundle-install.sh

  Uninstall:
    bash omniclaude/scripts/tick-bundle-uninstall.sh
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.omninode.cron-closeout</string>

  <key>ProgramArguments</key>
  <array>
    <string>__OMNI_HOME__/omniclaude/scripts/cron-closeout.sh</string>
  </array>

  <key>StartInterval</key>
  <integer>1800</integer><!-- 30 minutes -->

  <key>StandardOutPath</key>
  <string>/tmp/cron-closeout-stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/cron-closeout-stderr.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>__HOME__/.local/bin:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    <key>HOME</key>
    <string>__HOME__</string>
    <key>OMNI_HOME</key>
    <string>__OMNI_HOME__</string>
  </dict>

  <key>KeepAlive</key>
  <false/>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
